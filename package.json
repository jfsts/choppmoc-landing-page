{
  "name": "choppmoc-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy:s3": "npm run build && aws s3 sync dist s3://www.choppmoc.com.br/ --delete",
    "deploy:cloudfront": "aws cloudfront create-invalidation --distribution-id E3FAVSVYTCG0E6 --paths \"/*\"",
    "deploy": "npm run deploy:s3 && npm run deploy:cloudfront"
  },
  "dependencies": {
    "hamburger-react": "^2.5.1",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "vite": "^5.3.1"
  }
}
